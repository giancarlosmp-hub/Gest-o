[Unit]
Description=Demetra CRM
After=docker.service

[Service]
WorkingDirectory=/apps/gest-o
ExecStart=/bin/bash -lc 'set -a; [ ! -f /root/demetra-env/.env ] || . /root/demetra-env/.env; set +a; exec /usr/bin/docker compose up -d'
ExecStop=/usr/bin/docker compose down
Restart=always

[Install]
WantedBy=multi-user.target
