DATABASE_URL=postgresql://postgres@db:5432/salesforce_pro?schema=public
PORT=4000
FRONTEND_URL=https://crm.demetraagronegocios.com.br
CORS_ALLOWED_ORIGINS=https://crm.demetraagronegocios.com.br
JWT_ACCESS_SECRET=super-access
JWT_REFRESH_SECRET=super-refresh
VITE_API_URL=https://crm.demetraagronegocios.com.br/api
ENABLE_SMOKE_BOOTSTRAP=false
SEED_ON_BOOTSTRAP=false
ADMIN_BOOTSTRAP_ENABLED=false

# Integração backend para consulta segura de CNPJ
# O docker-compose repassa estas variáveis diretamente para o serviço `api`.
# Produção/VPS: configure no arquivo .env do backend/compose e faça redeploy sem apagar volumes.
# Defaults seguros para BrasilAPI (sem API key obrigatória):
CNPJ_LOOKUP_PROVIDER=brasilapi
CNPJ_LOOKUP_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
# Opcional para providers que exigem autenticação; nunca exponha no frontend
CNPJ_LOOKUP_API_KEY=
# Exemplo com provider genérico:
# CNPJ_LOOKUP_PROVIDER=generic
# CNPJ_LOOKUP_BASE_URL=https://api.seu-provedor.com/cnpj/{cnpj}
# CNPJ_LOOKUP_API_KEY=seu-token-aqui
