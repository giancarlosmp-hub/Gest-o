generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  diretor
  gerente
  vendedor
}

enum OpportunityStage {
  prospeccao
  negociacao
  proposta
  ganho
  perdido
}

enum ActivityType {
  ligacao
  whatsapp
  visita
  reuniao
  followup
  proposta_enviada
  proposta_negociacao
  fechamento
  envio_proposta
  visita_tecnica
  cliente_novo
  follow_up
}

enum EventType {
  comentario
  mudanca_etapa
  status
}

enum ClientType {
  PJ
  PF
}

enum AgendaEventType {
  reuniao_online
  reuniao_presencial
  roteiro_visita
  followup
}

enum AgendaEventStatus {
  agendado
  realizado
  vencido
}

enum OpportunityItemDiscountType {
  value
  percent
}

model User {
  id                        String                 @id @default(cuid())
  name                      String
  email                     String                 @unique
  passwordHash              String
  role                      Role
  region                    String?
  erpCode                   String?
  erpOperatorCode           String?
  erpRawPayload             Json?
  erpLoginUsername          String?
  erpLoginPasswordEncrypted String?
  erpLoginLastTestStatus    String?
  erpLoginLastTestAt        DateTime?
  isActive                  Boolean                @default(true)
  createdAt                 DateTime               @default(now())
  clients                   Client[]
  contacts                  Contact[]
  opportunities             Opportunity[]
  erpOrderSyncs             ErpOrderSync[]
  opportunityChangeLogs     OpportunityChangeLog[]
  activities                Activity[]
  timelineEvents            TimelineEvent[]
  communicationConversations CommunicationConversation[]
  goals                     Goal[]
  activityKpis              ActivityKPI[]
  sales                     Sale[]
  agendaEvents              AgendaEvent[]
  territoryCities           SellerTerritoryCity[]
  knowledgeDocuments        KnowledgeDocument[]
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  title       String
  category    String
  sourceType  String
  sourceName  String?
  content     String
  summary     String?
  tags        String[] @default([])
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([sourceType])
  @@index([isActive])
  @@index([createdById])
}

model Client {
  id                String          @id @default(cuid())
  code              String?
  fantasyName       String?
  name              String
  nameNormalized    String?         @db.VarChar(255)
  city              String
  cityNormalized    String?         @db.VarChar(255)
  state             String
  region            String
  potentialHa       Float?          @default(0)
  farmSizeHa        Float?          @default(0)
  clientType        ClientType      @default(PJ)
  cnpj              String?
  cnpjNormalized    String?         @db.VarChar(32)
  segment           String?
  lastPurchaseDate  DateTime?
  lastPurchaseValue Float?
  erpUpdatedAt      DateTime?
  isArchived        Boolean         @default(false)
  archiveReason     String?
  financialProfile  Json?
  partnerTitles     Json?
  openTitlesTotal   Float?          @default(0)
  overdueTitlesTotal Float?         @default(0)
  ownerSellerId     String
  ownerSeller       User            @relation(fields: [ownerSellerId], references: [id])
  contacts          Contact[]
  opportunities     Opportunity[]
  timelineEvents    TimelineEvent[]
  communicationConversations CommunicationConversation[]
  createdAt         DateTime        @default(now())
  agendaEvents      AgendaEvent[]
  agendaStops       AgendaStop[]
  activities        Activity[]

  @@index([code])
  @@index([fantasyName])
  @@index([isArchived])
}

model AgendaEvent {
  id            String            @id @default(cuid())
  title         String
  type          AgendaEventType
  startDateTime DateTime
  endDateTime   DateTime
  status        AgendaEventStatus @default(agendado)
  notes         String?
  city          String?
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id])
  opportunityId String?
  opportunity   Opportunity?      @relation(fields: [opportunityId], references: [id])
  sellerId      String
  seller        User              @relation(fields: [sellerId], references: [id])
  stops         AgendaStop[]
  activities    Activity[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([sellerId, startDateTime])
  @@index([startDateTime, endDateTime])
  @@index([opportunityId])
}

model AgendaStop {
  id               String      @id @default(cuid())
  agendaEventId    String
  agendaEvent      AgendaEvent @relation(fields: [agendaEventId], references: [id], onDelete: Cascade)
  order            Int
  clientId         String?
  client           Client?     @relation(fields: [clientId], references: [id])
  city             String?
  address          String?
  plannedTime      DateTime?
  notes            String?
  checkInAt        DateTime?
  checkInLat       Float?
  checkInLng       Float?
  checkInAccuracy  Float?
  checkOutAt       DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutAccuracy Float?
  resultStatus     String?
  resultReason     String?
  resultSummary    String?
  nextStep         String?
  nextStepDate     DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([agendaEventId, order])
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String
  role          String?
  department    String?
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  isPrimary     Boolean  @default(false)
  notes         String?
  ownerSellerId String
  ownerSeller   User     @relation(fields: [ownerSellerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Opportunity {
  id                   String                 @id @default(cuid())
  title                String
  value                Float
  stage                OpportunityStage
  crop                 String?
  season               String?
  areaHa               Float?
  productOffered       String?
  plantingForecastDate DateTime?
  expectedTicketPerHa  Float?
  proposalDate         DateTime
  followUpDate         DateTime
  expectedCloseDate    DateTime
  closedAt             DateTime?
  lastContactAt        DateTime?
  probability          Int?
  notes                String?
  priceTableCode       String?                @default("1")
  clientId             String
  client               Client                 @relation(fields: [clientId], references: [id])
  ownerSellerId        String
  ownerSeller          User                   @relation(fields: [ownerSellerId], references: [id])
  activities           Activity[]
  agendaEvents         AgendaEvent[]
  timelineEvents       TimelineEvent[]
  changeLogs           OpportunityChangeLog[]
  items                OpportunityItem[]
  erpOrderSyncs        ErpOrderSync[]
  createdAt            DateTime               @default(now())
}

model OpportunityChangeLog {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User        @relation(fields: [actorId], references: [id])
  field         String
  oldValue      String?
  newValue      String?
  createdAt     DateTime    @default(now())

  @@index([opportunityId, createdAt])
}

model TimelineEvent {
  id            String       @id @default(cuid())
  type          EventType
  description   String
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  ownerSellerId String
  ownerSeller   User         @relation(fields: [ownerSellerId], references: [id])
  createdAt     DateTime     @default(now())
}

model Activity {
  id              String       @id @default(cuid())
  type            ActivityType
  notes           String
  description     String?
  result          String?
  dueDate         DateTime
  date            DateTime?
  duration        Int?
  city            String?
  crop            String?
  areaEstimated   Float?
  product         String?
  checkInAt       DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkInAccuracy Float?
  done            Boolean      @default(false)
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id])
  opportunityId   String?
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id])
  agendaEventId   String?
  agendaEvent     AgendaEvent? @relation(fields: [agendaEventId], references: [id], onDelete: SetNull)
  ownerSellerId   String
  ownerSeller     User         @relation(fields: [ownerSellerId], references: [id])
  createdAt       DateTime     @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  month       String
  targetValue Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sellerId, month])
}

model ActivityKPI {
  id          String   @id @default(cuid())
  sellerId    String
  type        String
  month       String
  targetValue Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller User @relation(fields: [sellerId], references: [id])

  @@unique([sellerId, month, type])
}

model Sale {
  id        String   @id @default(cuid())
  date      DateTime
  value     Float
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id])
  createdAt DateTime @default(now())
}

model SellerTerritoryCity {
  id        String   @id @default(cuid())
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  state     String
  city      String
  ibgeCode  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sellerId, state, city])
  @@index([sellerId])
  @@index([state, city])
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CultureCatalog {
  id                      String   @id @default(uuid())
  slug                    String   @unique
  label                   String
  category                String   @default("Outras")
  isActive                Boolean  @default(true)
  defaultKgHaMin          Float?
  defaultKgHaMax          Float?
  goalsJson               Json
  notes                   String?
  pmsDefault              Float?
  germinationDefault      Float?
  purityDefault           Float?
  populationTargetDefault Float?
  rowSpacingCmDefault     Float?
  tags                    String[] @default([])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([isActive])
}

model Product {
  id                  String            @id @default(cuid())
  erpProductCode      String
  erpProductClassCode String
  name                String
  className           String?
  unit                String?
  brand               String?
  groupName           String?
  isActive            Boolean           @default(true)
  isSuspended         Boolean           @default(false)
  stockQuantity       Float?
  minPrice            Float?
  defaultPrice        Float?
  rawErpPayload       Json?
  prices              ProductPrice[]
  opportunityItems    OpportunityItem[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([erpProductCode, erpProductClassCode])
  @@index([name])
}

model ProductPrice {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  erpPriceId String?
  branchCode String?
  validFrom  DateTime?
  price      Float
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([productId])
  @@index([branchCode])
}

model OpportunityItem {
  id                  String                      @id @default(cuid())
  opportunityId       String
  opportunity         Opportunity                 @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?                    @relation(fields: [productId], references: [id], onDelete: SetNull)
  lineNumber          Int
  erpProductCode      String
  erpProductClassCode String
  productNameSnapshot String
  unit                String?
  quantity            Float
  unitPrice           Float
  discountType        OpportunityItemDiscountType @default(value)
  discountValue       Float                       @default(0)
  grossTotal          Float
  discountTotal       Float
  netTotal            Float
  notes               String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@unique([opportunityId, lineNumber])
  @@index([opportunityId])
  @@index([productId])
}

enum ErpOrderSyncStatus {
  pending
  sent
  error
}

enum ErpOrderFulfillmentStatus {
  pendente
  faturado
  parcial
  cancelado
  entregue
}

model ErpOrderSync {
  id                 String                     @id @default(cuid())
  opportunityId      String
  opportunity        Opportunity                @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  sellerId           String
  seller             User                       @relation(fields: [sellerId], references: [id])
  pedidoIdImportacao String                     @unique
  numPedido          String?
  erpOrderNumber     String?
  status             ErpOrderSyncStatus         @default(pending)
  orderStatus        ErpOrderFulfillmentStatus?
  payloadSent        Json
  erpResponse        Json?
  syncErrors         Json?
  lastStatusPayload  Json?
  sentAt             DateTime?
  statusSyncedAt     DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([opportunityId, createdAt])
  @@index([status])
  @@index([orderStatus])
  @@index([numPedido])
}

enum ErpSyncRunStatus {
  running
  success
  error
  skipped
}

enum ErpSyncTrigger {
  manual
  scheduler
}

model ErpSyncRun {
  id            String           @id @default(cuid())
  scope         String
  trigger       ErpSyncTrigger   @default(manual)
  status        ErpSyncRunStatus @default(running)
  sellerId      String?
  sellerName    String?
  authMode      String           @default("global")
  correlationId String?
  startedAt     DateTime         @default(now())
  finishedAt    DateTime?
  durationMs    Int?
  syncedCount   Int              @default(0)
  metrics       Json?
  errors        Json?
  errorMessage  String?
  createdAt     DateTime         @default(now())

  @@index([scope, startedAt])
  @@index([sellerId, startedAt])
  @@index([authMode, startedAt])
  @@index([status, startedAt])
}

model ErpSyncLock {
  scope       String   @id
  runId       String
  lockedUntil DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lockedUntil])
}

enum CommunicationChannelType {
  WHATSAPP
  INSTAGRAM
  FACEBOOK_MESSENGER
  EMAIL
  SMS
  RCS
  TELEGRAM
  WEBSITE_CHAT
  OTHER
}

enum CommunicationProviderType {
  META_WHATSAPP_CLOUD
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum CommunicationMessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  CONTACT
  STICKER
  REACTION
  INTERACTIVE
  TEMPLATE
  UNKNOWN
}

enum CommunicationMessageStatus {
  RECEIVED
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum CommunicationConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ARCHIVED
  BLOCKED
}

enum CommunicationWebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DUPLICATE
}

model CommunicationConversation {
  id                      String                          @id @default(cuid())
  channel                 CommunicationChannelType
  provider                CommunicationProviderType
  externalConversationKey String
  externalAccountId       String
  tenantId                String?                         @db.VarChar(64)
  clientId                String?
  client                  Client?                         @relation(fields: [clientId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  assignedSellerId        String?
  assignedSeller          User?                           @relation(fields: [assignedSellerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  contactNormalized       String?                         @db.VarChar(32)
  contactDisplay          String?                         @db.VarChar(64)
  contactName             String?                         @db.VarChar(120)
  status                  CommunicationConversationStatus @default(OPEN)
  lastMessageAt           DateTime?
  lastInboundAt           DateTime?
  lastOutboundAt          DateTime?
  unreadCount             Int                             @default(0)
  previewSanitized        String?                         @db.VarChar(240)
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  messages                CommunicationMessage[]

  @@unique([provider, externalAccountId, externalConversationKey])
  @@index([tenantId])
  @@index([clientId])
  @@index([assignedSellerId])
  @@index([contactNormalized])
  @@index([status])
  @@index([lastMessageAt])
}

model CommunicationMessage {
  id                       String                     @id @default(cuid())
  conversationId           String
  conversation             CommunicationConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  channel                  CommunicationChannelType
  provider                 CommunicationProviderType
  externalMessageId        String
  externalAccountId        String
  tenantId                 String?                    @db.VarChar(64)
  direction                CommunicationDirection
  type                     CommunicationMessageType
  textContent              String?
  mediaMetadata            Json?
  providerTimestamp        DateTime?
  replyToExternalMessageId String?
  status                   CommunicationMessageStatus @default(RECEIVED)
  errorSanitized           String?                    @db.VarChar(240)
  metadata                 Json?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@unique([provider, externalAccountId, externalMessageId])
  @@index([conversationId])
  @@index([tenantId])
  @@index([providerTimestamp])
  @@index([status])
}

model CommunicationWebhookEvent {
  id               String                     @id @default(cuid())
  channel          CommunicationChannelType
  provider         CommunicationProviderType
  externalEventKey String
  externalAccountId String
  tenantId         String?                    @db.VarChar(64)
  eventType        String                     @db.VarChar(64)
  payloadHash      String                     @db.VarChar(64)
  status           CommunicationWebhookStatus @default(RECEIVED)
  attempts         Int                        @default(0)
  processedAt      DateTime?
  errorSanitized   String?                    @db.VarChar(240)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([provider, externalAccountId, externalEventKey])
  @@index([tenantId])
  @@index([status, createdAt])
  @@index([payloadHash])
}
