generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  diretor
  gerente
  vendedor
}

enum OpportunityStage {
  prospeccao
  negociacao
  proposta
  ganho
  perdido
}

enum ActivityType {
  ligacao
  whatsapp
  visita
  reuniao
  followup
  proposta_enviada
  proposta_negociacao
  fechamento
  envio_proposta
  visita_tecnica
  cliente_novo
  follow_up
}

enum EventType {
  comentario
  mudanca_etapa
  status
}

enum ClientType {
  PJ
  PF
}

enum AgendaEventType {
  reuniao_online
  reuniao_presencial
  roteiro_visita
  followup
}

enum AgendaEventStatus {
  agendado
  realizado
  vencido
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         Role
  region       String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  clients      Client[]
  contacts     Contact[]
  opportunities Opportunity[]
  opportunityChangeLogs OpportunityChangeLog[]
  activities   Activity[]
  timelineEvents TimelineEvent[]
  goals        Goal[]
  activityKpis ActivityKPI[]
  sales        Sale[]
  agendaEvents AgendaEvent[]
}

model Client {
  id             String        @id @default(cuid())
  name           String
  nameNormalized String?       @db.VarChar(255)
  city           String
  cityNormalized String?       @db.VarChar(255)
  state          String
  region         String
  potentialHa    Float?        @default(0)
  farmSizeHa     Float?        @default(0)
  clientType     ClientType    @default(PJ)
  cnpj           String?
  cnpjNormalized String?       @db.VarChar(32)
  segment        String?
  ownerSellerId  String
  ownerSeller    User          @relation(fields: [ownerSellerId], references: [id])
  contacts       Contact[]
  opportunities  Opportunity[]
  timelineEvents TimelineEvent[]
  createdAt      DateTime      @default(now())
  agendaEvents   AgendaEvent[]
  agendaStops    AgendaStop[]
  activities     Activity[]
}

model AgendaEvent {
  id            String            @id @default(cuid())
  title         String
  type          AgendaEventType
  startDateTime DateTime
  endDateTime   DateTime
  status        AgendaEventStatus @default(agendado)
  notes         String?
  city          String?
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id])
  opportunityId String?
  opportunity   Opportunity?      @relation(fields: [opportunityId], references: [id])
  sellerId      String
  seller        User              @relation(fields: [sellerId], references: [id])
  stops         AgendaStop[]
  activities    Activity[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([sellerId, startDateTime])
  @@index([startDateTime, endDateTime])
  @@index([opportunityId])
}

model AgendaStop {
  id            String      @id @default(cuid())
  agendaEventId String
  agendaEvent   AgendaEvent @relation(fields: [agendaEventId], references: [id], onDelete: Cascade)
  order         Int
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  city          String?
  address       String?
  plannedTime   DateTime?
  notes         String?
  checkInAt       DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkInAccuracy Float?
  checkOutAt       DateTime?
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutAccuracy Float?
  resultStatus  String?
  resultReason  String?
  resultSummary String?
  nextStep      String?
  nextStepDate  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([agendaEventId, order])
}


model Contact {
  id            String    @id @default(cuid())
  name          String
  phone         String
  email         String
  role          String?
  department    String?
  clientId      String?
  client        Client?   @relation(fields: [clientId], references: [id])
  isPrimary     Boolean   @default(false)
  notes         String?
  ownerSellerId String
  ownerSeller   User      @relation(fields: [ownerSellerId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Opportunity {
  id                String           @id @default(cuid())
  title             String
  value             Float
  stage             OpportunityStage
  crop              String?
  season            String?
  areaHa            Float?
  productOffered    String?
  plantingForecastDate DateTime?
  expectedTicketPerHa Float?
  proposalDate      DateTime
  followUpDate      DateTime
  expectedCloseDate DateTime
  closedAt          DateTime?
  lastContactAt     DateTime?
  probability       Int?
  notes             String?
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  ownerSellerId     String
  ownerSeller       User             @relation(fields: [ownerSellerId], references: [id])
  activities        Activity[]
  agendaEvents      AgendaEvent[]
  timelineEvents    TimelineEvent[]
  changeLogs        OpportunityChangeLog[]
  createdAt         DateTime         @default(now())
}

model OpportunityChangeLog {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User        @relation(fields: [actorId], references: [id])
  field         String
  oldValue      String?
  newValue      String?
  createdAt     DateTime    @default(now())

  @@index([opportunityId, createdAt])
}

model TimelineEvent {
  id            String       @id @default(cuid())
  type          EventType
  description   String
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  ownerSellerId String
  ownerSeller   User         @relation(fields: [ownerSellerId], references: [id])
  createdAt     DateTime     @default(now())
}

model Activity {
  id            String       @id @default(cuid())
  type          ActivityType
  notes         String
  description   String?
  result        String?
  dueDate       DateTime
  date          DateTime?
  duration      Int?
  city          String?
  crop          String?
  areaEstimated Float?
  product       String?
  checkInAt     DateTime?
  checkInLat    Float?
  checkInLng    Float?
  checkInAccuracy Float?
  done          Boolean      @default(false)
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  agendaEventId String?
  agendaEvent   AgendaEvent? @relation(fields: [agendaEventId], references: [id], onDelete: SetNull)
  ownerSellerId String
  ownerSeller   User         @relation(fields: [ownerSellerId], references: [id])
  createdAt     DateTime     @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  month       String
  targetValue Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sellerId, month])
}

model ActivityKPI {
  id          String   @id @default(cuid())
  sellerId    String
  type        String
  month       String
  targetValue Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller      User     @relation(fields: [sellerId], references: [id])

  @@unique([sellerId, month, type])
}

model Sale {
  id        String   @id @default(cuid())
  date      DateTime
  value     Float
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id])
  createdAt DateTime @default(now())
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CultureCatalog {
  id                      String   @id @default(uuid())
  slug                    String   @unique
  label                   String
  category                String   @default("Outras")
  isActive                Boolean  @default(true)
  defaultKgHaMin          Float?
  defaultKgHaMax          Float?
  goalsJson               Json
  notes                   String?
  pmsDefault              Float?
  germinationDefault      Float?
  purityDefault           Float?
  populationTargetDefault Float?
  rowSpacingCmDefault     Float?
  tags                    String[] @default([])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([isActive])
}
